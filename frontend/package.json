{
	"name": "agent-orchestrator",
	"productName": "Agent Orchestrator",
	"version": "0.10.0",
	"private": true,
	"description": "Electron + TypeScript frontend for the agent-orchestrator rewrite",
	"author": "Agent Orchestrator",
	"license": "MIT",
	"homepage": "https://github.com/aoagents/agent-orchestrator",
	"main": ".vite/build/main.js",
	"repository": {
		"type": "git",
		"url": "https://github.com/aoagents/agent-orchestrator"
	},
	"scripts": {
		"build:daemon": "node ./scripts/build-daemon.mjs",
		"dev": "electron-forge start",
		"dev:web": "VITE_NO_ELECTRON=1 vite --config vite.renderer.config.ts",
		"prepackage": "npm run build:daemon",
		"package": "electron-forge package",
		"premake": "npm run build:daemon",
		"make": "electron-forge make",
		"publish": "npm run build:daemon && electron-forge publish",
		"typecheck": "tsc --noEmit",
		"test": "vitest run --config vite.renderer.config.ts",
		"test:e2e": "playwright test",
		"api:ts": "openapi-typescript ../backend/internal/httpd/apispec/openapi.yaml -o src/api/schema.ts"
	},
	"devDependencies": {
		"@electron-forge/cli": "^7.11.2",
		"@electron-forge/maker-base": "^7.11.2",
		"@electron-forge/maker-deb": "^7.11.2",
		"@electron-forge/maker-rpm": "^7.11.2",
		"@electron-forge/maker-zip": "^7.11.2",
		"@electron-forge/plugin-vite": "^7.11.2",
		"@electron-forge/publisher-github": "^7.11.2",
		"@playwright/test": "^1.61.1",
		"@tailwindcss/vite": "^4.3.2",
		"@tanstack/router-plugin": "^1.168.19",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.3",
		"app-builder-lib": "^26.15.3",
		"electron": "^43.1.0",
		"jsdom": "^29.1.1",
		"openapi-typescript": "^7.13.0",
		"playwright": "^1.61.1",
		"tailwindcss": "^4.3.2",
		"typescript": "^5.9.3",
		"vite": "^8.1.4",
		"vitest": "^4.1.10"
	},
	"dependencies": {
		"@radix-ui/react-dialog": "^1.1.19",
		"@radix-ui/react-slot": "^1.3.0",
		"@radix-ui/react-tabs": "^1.1.17",
		"@radix-ui/react-tooltip": "^1.2.12",
		"@tanstack/react-query": "^5.101.2",
		"@tanstack/react-router": "^1.170.17",
		"@xterm/addon-canvas": "^0.7.0",
		"@xterm/addon-fit": "^0.10.0",
		"@xterm/addon-search": "^0.15.0",
		"@xterm/addon-unicode11": "^0.9.0",
		"@xterm/addon-web-links": "^0.11.0",
		"@xterm/addon-webgl": "^0.19.0",
		"@xterm/xterm": "^5.5.0",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"electron-updater": "^6.8.9",
		"lucide-react": "^1.23.0",
		"openapi-fetch": "^0.17.0",
		"posthog-js": "^1.399.0",
		"radix-ui": "^1.6.2",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"react-resizable-panels": "^4.12.1",
		"tailwind-merge": "^3.6.0",
		"zustand": "^5.0.14"
	},
	"optionalDependencies": {
		"electron-installer-debian": "^4.0.0",
		"electron-installer-redhat": "^4.0.0"
	}
}
