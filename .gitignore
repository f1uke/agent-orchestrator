# Node / Electron
node_modules/
.pnpm/
dist/
out/
build/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Go
.go/
bin/
*.test
*.out
vendor/
# Compiled Go binaries. `go build` writes its output into the working directory
# under whatever name `-o` chooses, and Git cannot match "an executable" by
# pattern, so naming the binaries individually never keeps up. Instead ignore
# every extensionless file directly inside backend/ - the module root, and the
# cwd for every go command in AGENTS.md. Subdirectories and anything with an
# extension stay tracked as before; if you add an extensionless file here that
# belongs in Git (a Makefile, say), re-include it with a `!` line.
# Better still: build to a temp path (`go run`, `go build -o /tmp/...`).
/backend/*
!/backend/*/
!/backend/*.*
# Windows binaries carry an extension, so this must stay below the re-inclusion
# above to win over it (last matching rule decides).
*.exe
agent-orchestrator.yaml

# Backend runtime data artifacts (SQLite store + WAL, CDC event log).
# Created at AO_DATA_DIR (outside the repo by default); ignored here so a
# data dir pointed at the tree never gets committed.
*.db
*.db-shm
*.db-wal
session-events.jsonl
session-events.jsonl.*

# Agent Orchestrator local session state
.ao/

# AO reviewer scratch output. The reviewer agent runs inside the worker's
# worktree; its review writeup must never be committed onto the worker branch.
/review.md

# Environment
.direnv/
.env
.env.*
!.env.example

# Editor / IDE
.vscode/
.idea/
*.swp
*~

# Local tooling (not for the team)
.codegraph/
.cursor/

# Claude Code local scaffolding (never shared): the native worktrees dir and
# per-user local settings. A shared .claude/settings.json (or commands/skills)
# stays trackable — only the local-only junk is ignored here.
.claude/worktrees/
.claude/settings.local.json

# OS
.DS_Store
Thumbs.db

# Personal local overrides (not for the team)
.envrc.local

# electron-forge / vite build output
.vite/
dist-electron/
# electron-builder debug dump, written to the cwd on every NSIS build
builder-debug.yml

# playwright artifacts
frontend/test-results/

# built daemon binary copied into the frontend bundle dir
frontend/daemon/
